{
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "index.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "index.py"
    },
    {
      "src": "/files/(.*)",
      "dest": "index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
